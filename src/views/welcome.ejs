<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>InGame — Добро пожаловать</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <h1><%= welcomeText.title %></h1>
    <p><%= welcomeText.intro %></p>

    <section class="info-block">
      <h2><%= welcomeText.howToTitle %></h2>
      <ol>
        <% welcomeText.howToSteps.forEach((step) => { %>
          <li><%= step %></li>
        <% }) %>
      </ol>
    </section>

    <section class="info-block">
      <h2><%= welcomeText.createFromScratchTitle %></h2>
      <p><%= welcomeText.createFromScratchDescription %></p>
    </section>

    <nav class="links">
      <a href="/quests"><%= welcomeText.links.quests %></a>
      <a href="/quests/new"><%= welcomeText.links.newQuest %></a>
    </nav>
  </main>
</body>
</html>
