<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>InGame — <%= quest.title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <div class="nav-controls" data-quest-id="<%= quest.id %>" data-root-location-id="<%= quest.root_location_id %>" data-current-location-id="<%= currentLocation.id %>">
      <button type="button" class="js-step-back">На шаг назад</button>
      <button type="button" class="js-restart">Начать заново</button>
    </div>
    <p class="hint-text" id="nav-hint" <% if (!navMessage) { %>hidden<% } %>>
      <% if (navMessage === 'invalid-history-location') { %>
        Локация из истории недоступна. Вы перемещены в актуальную точку квеста.
      <% } %>
    </p>
    <h1><%= quest.title %></h1>
    <p><strong>Кратко:</strong> <%= quest.short_description %></p>
    <p><strong>Событие:</strong> <%= currentLocation.event_text %></p>
    <% if (currentLocation.image_url) { %>
      <img src="<%= currentLocation.image_url %>" alt="Иллюстрация локации" style="max-width: 100%; border-radius: 8px;" />
    <% } %>
    <p><strong>Автор локации:</strong> <%= currentLocation.author %></p>
    <p><strong>Создано:</strong> <%= currentLocation.created_at %></p>
    <p><strong>Узлов в дереве:</strong> <%= treeNodes.length %>, <strong>действий:</strong> <%= treeActions.length %></p>
    <p id="updates-banner" hidden>Появились новые продолжения. Страница будет обновлена…</p>

    <h2>Что сделать дальше?</h2>
    <div class="actions">
      <% actions.forEach((action) => { %>
        <form method="post" action="/quests/<%= quest.id %>/actions/<%= action.id %>/choose">
          <button type="submit">
            <%= action.action_text %>
            <% if (!action.child_location_id) { %>
              — ветка ещё не создана
            <% } %>
          </button>
        </form>
      <% }) %>
    </div>

    <p><a href="/quests">← Назад к списку</a></p>
  </main>
  <script>
    (function setupLocationNavigation() {
      const container = document.querySelector('.nav-controls');
      if (!container) return;
      const questId = Number(container.dataset.questId);
      const rootLocationId = Number(container.dataset.rootLocationId);
      const currentLocationId = Number(container.dataset.currentLocationId);
      const historyKey = `quest-nav-history:${questId}`;
      const hint = document.getElementById('nav-hint');
      const stepBackButton = container.querySelector('.js-step-back');
      const restartButton = container.querySelector('.js-restart');

      function showHint(text) {
        if (!hint) return;
        hint.hidden = false;
        hint.textContent = text;
      }

      function readHistory() {
        try {
          const parsed = JSON.parse(localStorage.getItem(historyKey) || '[]');
          return Array.isArray(parsed) ? parsed.filter((id) => Number.isInteger(id)) : [];
        } catch (e) {
          return [];
        }
      }

      function writeHistory(history) {
        localStorage.setItem(historyKey, JSON.stringify(history.slice(-100)));
      }

      const history = readHistory();
      const lastKnown = history[history.length - 1];
      if (lastKnown !== currentLocationId) {
        history.push(currentLocationId);
        writeHistory(history);
      }
      const canStepBack = history.length > 1;
      stepBackButton.disabled = !canStepBack;
      stepBackButton.title = canStepBack ? '' : 'Нет предыдущего шага в истории.';

      stepBackButton.addEventListener('click', () => {
        const localHistory = readHistory();
        if (localHistory.length <= 1) {
          showHint('Предыдущий шаг отсутствует.');
          stepBackButton.disabled = true;
          return;
        }
        localHistory.pop();
        const previousLocationId = localHistory[localHistory.length - 1];
        writeHistory(localHistory);
        window.location.href = `/quests/${questId}?locationId=${previousLocationId}`;
      });

      restartButton.addEventListener('click', () => {
        writeHistory([rootLocationId]);
        showHint('Квест начат заново с корневой локации.');
        window.location.href = `/quests/${questId}?locationId=${rootLocationId}`;
      });
    })();

    (function setupQuestUpdatesPolling() {
      const questId = <%= Number(quest.id) %>;
      let latestKnown = '<%= treeUpdatedAt %>';
      const banner = document.getElementById('updates-banner');

      async function checkUpdates() {
        try {
          const response = await fetch(`/quests/${questId}/updates?since=${encodeURIComponent(latestKnown)}`, {
            headers: { 'Accept': 'application/json' }
          });
          if (!response.ok) return;
          const payload = await response.json();
          if (payload && payload.latestCreatedAt) {
            latestKnown = payload.latestCreatedAt;
          }
          if (payload && payload.hasUpdates) {
            if (banner) banner.hidden = false;
            window.location.reload();
          }
        } catch (error) {
          // silent retry by the next polling iteration
        }
      }

      setInterval(checkUpdates, 5000);
    })();
  </script>
</body>
</html>
