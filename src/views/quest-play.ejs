<!doctype html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>InGame — <%= quest.title %></title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <main class="container">
    <h1><%= quest.title %></h1>
    <p><strong>Кратко:</strong> <%= quest.short_description %></p>
    <p><strong>Событие:</strong> <%= quest.event_text %></p>
    <% if (quest.image_url) { %>
      <img src="<%= quest.image_url %>" alt="Иллюстрация локации" style="max-width: 100%; border-radius: 8px;" />
    <% } %>
    <p><strong>Автор локации:</strong> <%= quest.author %></p>
    <p><strong>Создано:</strong> <%= quest.created_at %></p>

    <h2>Что сделать дальше?</h2>
    <div class="actions">
      <% actions.forEach((action) => { %>
        <button type="button">
          <%= action.action_text %>
          <% if (!action.child_location_id) { %>
            — ветка ещё не создана
          <% } %>
        </button>
      <% }) %>
    </div>

    <p><a href="/quests">← Назад к списку</a></p>
  </main>
</body>
</html>
